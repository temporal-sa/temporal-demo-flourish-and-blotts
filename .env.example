# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack (Socket Mode — no public URL required)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C...

# Temporal — runs on the host via `make dev` / `temporal server start-dev`.
# Docker Compose overrides TEMPORAL_HOST to host.docker.internal:7233 for containers;
# the value here is what you'd use when running workers/API directly on the host
# (e.g. codespaces without Docker).
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
# Base URL of the Temporal UI *namespace* view — deep links append /workflows/<id>.
# On Temporal Cloud set this to the derived namespace URL, e.g.
# https://cloud.temporal.io/namespaces/tmprl-dem-cld-flourish-and-blotts.<acct>
TEMPORAL_UI_URL=http://localhost:8233/namespaces/default

# API
API_HOST=0.0.0.0
API_PORT=8000
# Used to build Approve/Deny links embedded in customer HITL emails.
# The customer clicks these from their browser on the host, so localhost is correct.
API_BASE_URL=http://localhost:8000

# Customer HITL — MailHog captures outbound email for the demo.
# Docker Compose: SMTP_HOST=mailhog (service name). Local/Codespaces: SMTP_HOST=localhost.
SMTP_HOST=mailhog
SMTP_PORT=1025
MAILHOG_UI_URL=http://localhost:8025
HITL_FROM_EMAIL=orders@flourish-and-blotts.test
# HMAC secret for signing Approve/Deny email links. Rotate to invalidate outstanding links.
HITL_TOKEN_SECRET=change-me-in-demo
